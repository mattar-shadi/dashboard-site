@page "/"
@inject IJSRuntime JS

<PageTitle>Dashboard — NexusDash</PageTitle>

<div class="page-title">
    <h1>Bienvenue sur Nexus Dashboard</h1>
    <p>Aperçu de vos performances pour aujourd'hui, <span id="currentDate"></span></p>
</div>

<div class="stats-grid">
    <div class="card">
        <div class="stat-header">
            <div class="stat-icon" style="background: rgba(99, 102, 241, 0.1); color: var(--primary);">
                <i class="fas fa-euro-sign"></i>
            </div>
            <span class="trend trend-up"><i class="fas fa-arrow-up"></i> 14.2%</span>
        </div>
        <span class="stat-val">148 240 €</span>
        <span class="stat-label">Revenus ce mois</span>
    </div>

    <div class="card">
        <div class="stat-header">
            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">
                <i class="fas fa-users"></i>
            </div>
            <span class="trend trend-up"><i class="fas fa-arrow-up"></i> 8.1%</span>
        </div>
        <span class="stat-val">2 847</span>
        <span class="stat-label">Nouveaux Clients</span>
    </div>

    <div class="card">
        <div class="stat-header">
            <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: var(--warning);">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <span class="trend trend-down"><i class="fas fa-arrow-down"></i> 3.2%</span>
        </div>
        <span class="stat-val">1 394</span>
        <span class="stat-label">Commandes</span>
    </div>

    <div class="card">
        <div class="stat-header">
            <div class="stat-icon" style="background: rgba(239, 68, 68, 0.1); color: var(--danger);">
                <i class="fas fa-percentage"></i>
            </div>
            <span class="trend trend-up"><i class="fas fa-arrow-up"></i> 0.4%</span>
        </div>
        <span class="stat-val">4.8%</span>
        <span class="stat-label">Taux de Conversion</span>
    </div>
</div>

<div class="content-grid">
    <div class="card">
        <h3 style="font-size: 1.1rem;">Évolution des Revenus</h3>
        <div class="chart-container">
            <canvas id="mainChart"></canvas>
        </div>
    </div>
    <div class="card">
        <h3 style="font-size: 1.1rem;">Dernières Transactions</h3>
        <div class="table-responsive">
            <table>
                <caption class="sr-only">Dernières Transactions</caption>
                <thead>
                    <tr><th>Client</th><th>Montant</th><th>Statut</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="font-weight: 600;">Thomas Martin</td>
                        <td>2 450 €</td>
                        <td><span class="status status-paid">Payé</span></td>
                    </tr>
                    <tr>
                        <td style="font-weight: 600;">Sophie Dubois</td>
                        <td>980 €</td>
                        <td><span class="status status-pending">Attente</span></td>
                    </tr>
                    <tr>
                        <td style="font-weight: 600;">Lucas Bernard</td>
                        <td>3 120 €</td>
                        <td><span class="status status-paid">Payé</span></td>
                    </tr>
                    <tr>
                        <td style="font-weight: 600;">Emma Petit</td>
                        <td>450 €</td>
                        <td><span class="status status-pending">Attente</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("DashboardInterop.initDate");
            await JS.InvokeVoidAsync("DashboardInterop.initMainChart");
        }
    }
}
