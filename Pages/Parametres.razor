@page "/parametres"

<PageTitle>Paramètres — NexusDash</PageTitle>

<div class="page-title">
    <h1>Paramètres</h1>
    <p>Configuration de votre compte et préférences</p>
</div>

<div class="card">
    <h3 style="font-size: 1.1rem;">Paramètres du compte</h3>
    <form @onsubmit:preventDefault style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; max-width: 500px;">
        <div>
            <label for="display-name" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Nom d'affichage</label>
            <input id="display-name" name="display-name" type="text" value="Thomas Martin" autocomplete="name" aria-required="true" required style="width: 100%; padding: 0.75rem 1rem; background: var(--bg-dark); border: 1px solid #334155; border-radius: 10px; color: var(--text); font-family: inherit; font-size: 0.95rem;" />
        </div>
        <div>
            <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email</label>
            <input id="email" name="email" type="email" value="thomas@example.com" autocomplete="email" aria-required="true" required style="width: 100%; padding: 0.75rem 1rem; background: var(--bg-dark); border: 1px solid #334155; border-radius: 10px; color: var(--text); font-family: inherit; font-size: 0.95rem;" />
        </div>
        <div>
            <label for="language" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Langue</label>
            <select id="language" name="language" required style="width: 100%; padding: 0.75rem 1rem; background: var(--bg-dark); border: 1px solid #334155; border-radius: 10px; color: var(--text); font-family: inherit; font-size: 0.95rem;">
                <option value="fr">Français</option>
                <option value="en">English</option>
                <option value="es">Español</option>
            </select>
        </div>
        <div>
            <button type="submit" style="padding: 0.75rem 2rem; background: var(--primary); color: white; border: none; border-radius: 10px; font-family: inherit; font-size: 0.95rem; font-weight: 600; cursor: pointer;">Sauvegarder</button>
        </div>
    </form>
</div>
