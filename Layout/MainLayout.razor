@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="overlay" id="overlay"></div>

<aside class="sidebar" id="sidebar">
    <div class="logo">
        <i class="fas fa-bolt"></i>
        <span>Nexus<span style="color:var(--primary)">Dash</span></span>
    </div>
    <nav class="nav-menu" aria-label="Menu principal">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All"><i class="fas fa-th-large"></i> Dashboard</NavLink>
        <NavLink class="nav-link" href="analytics"><i class="fas fa-chart-line"></i> Analytics</NavLink>
        <NavLink class="nav-link" href="clients"><i class="fas fa-users"></i> Clients</NavLink>
        <NavLink class="nav-link" href="commandes"><i class="fas fa-shopping-bag"></i> Commandes</NavLink>
        <NavLink class="nav-link" href="finances"><i class="fas fa-wallet"></i> Finances</NavLink>
        <NavLink class="nav-link" href="parametres"><i class="fas fa-cog"></i> Paramètres</NavLink>
    </nav>
    <div style="padding: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05);">
        <button type="button" class="nav-link" style="color: var(--danger); background: none; border: none; padding: 0; cursor: pointer;">
            <i class="fas fa-sign-out-alt"></i> Déconnexion
        </button>
    </div>
</aside>

<div class="main-wrapper">
    <header>
        <div class="header-left">
            <button class="hamburger-btn" id="hamburgerBtn" title="Basculer le menu" aria-label="Basculer le menu" aria-expanded="false" aria-controls="sidebar">
                <i class="fas fa-bars"></i>
            </button>
            <div class="search-box" style="display: none;">
                <i class="fas fa-search"></i>
            </div>
        </div>

        <button id="themeToggle" aria-label="Basculer le thème" style="background: var(--bg-card); width: 42px; height: 42px; border-radius: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; transition: var(--transition);">
            <i class="fas fa-moon" id="themeIcon"></i>
        </button>

        <div class="user-profile">
            <div class="user-info">
                <span class="name">Thomas Martin</span>
                <span class="role">Admin Principal</span>
            </div>
            <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Photo de profil de Thomas Martin">
        </div>
    </header>

    <main>
        @Body
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("DashboardInterop.init");
        }
    }
}
